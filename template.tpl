- name: ads_data_redaction and url_passthrough flags forwarded to gtag
  code: |-
    const gtagCalls = [];
    mock('setDefaultConsentState', () => {});
    mock('updateConsentState', () => {});
    mock('callInWindow', (fn, action, key, value) => {
      gtagCalls.push({ fn: fn, action: action, key: key, value: value });
    });
    mock('addEventListener', () => {});
    mock('injectScript', () => {});
    mock('logToConsole', () => {});
    mock('encodeUriComponent', (s) => s);

    runCode({
      shopId: 'test.myshopify.com',
      regionBehavior: 'eea_denied',
      waitForUpdate: 500,
      adsDataRedaction: true,
      urlPassthrough: true,
      injectBanner: false,
    });

    assertThat(gtagCalls.length).isEqualTo(2);
    assertThat(gtagCalls[0].fn).isEqualTo('gtag');
    assertThat(gtagCalls[0].action).isEqualTo('set');
    assertThat(gtagCalls[0].key).isEqualTo('ads_data_redaction');
    assertThat(gtagCalls[0].value).isEqualTo(true);
    assertThat(gtagCalls[1].key).isEqualTo('url_passthrough');
    assertThat(gtagCalls[1].value).isEqualTo(true);

- name: Banner consent event triggers updateConsentState with mapped signals
  code: |-
    let storedHandler = null;
    const updateCalls = [];
    mock('setDefaultConsentState', () => {});
    mock('updateConsentState', (state) => {
      updateCalls.push(state);
    });
    mock('callInWindow', () => {});
    mock('addEventListener', (eventName, handler) => {
      if (eventName === 'cookieConsentUpdated') storedHandler = handler;
    });
    mock('injectScript', () => {});
    mock('logToConsole', () => {});
    mock('encodeUriComponent', (s) => s);

    runCode({
      shopId: 'test.myshopify.com',
      regionBehavior: 'eea_denied',
      waitForUpdate: 500,
      adsDataRedaction: false,
      urlPassthrough: false,
      injectBanner: false,
    });

    // Simulate the banner dispatching its consent event.
    assertThat(storedHandler).isNotEqualTo(null);
    storedHandler({
      detail: {
        analytics: true,
        marketing: true,
        preferences: false,
      },
    });

    assertThat(updateCalls.length).isEqualTo(1);
    assertThat(updateCalls[0].ad_storage).isEqualTo('granted');
    assertThat(updateCalls[0].ad_user_data).isEqualTo('granted');
    assertThat(updateCalls[0].ad_personalization).isEqualTo('granted');
    assertThat(updateCalls[0].analytics_storage).isEqualTo('granted');
    assertThat(updateCalls[0].personalization_storage).isEqualTo('denied');

