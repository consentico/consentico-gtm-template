___TESTS___

scenarios:
- name: EEA-denied (default) emits two consent default calls
  code: |-
    const setDefaultCalls = [];
    mock('setDefaultConsentState', (state) => {
      setDefaultCalls.push(state);
    });
    mock('updateConsentState', () => {});
    mock('callInWindow', () => {});
    mock('addEventListener', () => {});
    mock('injectScript', () => {});
    mock('logToConsole', () => {});
    mock('encodeUriComponent', (s) => s);

    runCode({
      shopId: 'test.myshopify.com',
      regionBehavior: 'eea_denied',
      waitForUpdate: 500,
      adsDataRedaction: false,
      urlPassthrough: false,
      injectBanner: false,
    });

    // Two `setDefaultConsentState` calls: one regional (denied, with
    // `region` array) and one global (granted, no `region`). Order
    // matters — the regional call must be first so the global one
    // doesn't override it.
    assertThat(setDefaultCalls.length).isEqualTo(2);
    assertThat(setDefaultCalls[0].ad_storage).isEqualTo('denied');
    assertThat(setDefaultCalls[0].analytics_storage).isEqualTo('denied');
    assertThat(setDefaultCalls[0].region).isDefined();
    assertThat(setDefaultCalls[1].ad_storage).isEqualTo('granted');
    assertThat(setDefaultCalls[1].analytics_storage).isEqualTo('granted');
    assertApi('gtmOnSuccess').wasCalled();

